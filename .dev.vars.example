NEXTJS_ENV=development

# Local dev only (.dev.vars). For Cloudflare Workers Builds, also add these as
# "Build variables and secrets". For production runtime, set the same keys as
# Worker variables/secrets in the dashboard.
CLOUDFLARE_D1_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

RESEND_API_KEY=
RESEND_DOMAIN=noreply@send.ddrtrace.xyz

GOOGLE_GENERATIVE_AI_API_KEY=
